{
  "name": "tastmap",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Browser tool that turns OpenStreetMap data into tactile maps (Schwellpapier) as printable A4/A3 PDFs.",
  "license": "GPL-3.0-or-later",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "npm run build && wrangler dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "leaflet": "^1.9.4",
    "liblouis": "^0.4.0",
    "pdf-lib": "^1.17.1"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.42.1",
    "@types/leaflet": "^1.9.12",
    "typescript": "^5.6.3",
    "vite": "^6.4.3",
    "vitest": "^3.2.6",
    "wrangler": "^4.103.0"
  }
}
